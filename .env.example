# BIMA360 — Environment Variables
# Copy: cp .env.example .env
# Fill real values. NEVER commit .env to git.
# Production: AWS Secrets Manager only.

# App
ENVIRONMENT=development

# PostgreSQL
POSTGRES_USER=bima360
POSTGRES_PASSWORD=bima360pass
POSTGRES_DB=bima360
DATABASE_URL=postgresql+asyncpg://bima360:bima360pass@localhost:5432/bima360

# Redis
REDIS_URL=redis://localhost:6379

# Sarvam AI (primary)
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul-v2

# Groq (fallback — LLaMA 3.1, free 30 req/min)
GROQ_API_KEY=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=bima360-docs
AWS_COGNITO_AGENT_POOL_ID=
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=

# Hyperledger Fabric
FABRIC_CONNECTION_PROFILE_PATH=./blockchain/network/connection-profile.json
FABRIC_WALLET_PATH=./blockchain/wallets
FABRIC_CHANNEL_NAME=bima-channel
FABRIC_POLICY_CHAINCODE=policy
FABRIC_CLAIM_CHAINCODE=claim
FABRIC_MSP_ID=Bima360Org1MSP

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# SMS
MSG91_API_KEY=
MSG91_SENDER_ID=BIMA360
MSG91_TEMPLATE_OTP=

# IPFS
PINATA_API_KEY=
PINATA_SECRET_KEY=

# GCP
GCP_PROJECT_ID=
GCP_SA_KEY_PATH=./infra/gcp-sa-key.json

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_RAZORPAY_KEY=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# Monitoring
SENTRY_DSN=
